<Window x:Class="NetworkDiagramBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ネットワーク構成図作成ツール" Height="750" Width="1150"
        MinHeight="550" MinWidth="850"
        Background="{DynamicResource BgBrush}"
        FontFamily="Yu Gothic UI">

    <Window.Resources>
        <!-- === COLOR BRUSHES (動的テーマ対応) === -->
        <SolidColorBrush x:Key="BgBrush"          Color="#0D1117"/>
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#161B22"/>
        <SolidColorBrush x:Key="Surface2Brush"    Color="#21262D"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="#30363D"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#238636"/>
        <SolidColorBrush x:Key="Accent2Brush"     Color="#1F6FEB"/>
        <SolidColorBrush x:Key="Accent3Brush"     Color="#9E6A03"/>
        <SolidColorBrush x:Key="TextBrush"        Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#8B949E"/>
        <SolidColorBrush x:Key="TextDim"          Color="#484F58"/>
        <SolidColorBrush x:Key="DangerBrush"      Color="#DA3633"/>
        <SolidColorBrush x:Key="GreenBrush"       Color="#56D364"/>
        <SolidColorBrush x:Key="ComboHighBrush"   Color="#2D333B"/>
        <SolidColorBrush x:Key="AmberBrush"       Color="#C9922A"/>
        <SolidColorBrush x:Key="AmberBorderBrush" Color="#9E6A03"/>
        <SolidColorBrush x:Key="AmberHoverBrush"  Color="#2D1A00"/>

        <!-- === PRIMARY BUTTON === -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="Padding"          Value="18,8"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#238636" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2EA043"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                                <Setter Property="Foreground" Value="#484F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === SECONDARY BUTTON (テーマ対応) === -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === DANGER BUTTON === -->
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Foreground"      Value="#DA3633"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" BorderBrush="#DA3633"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D0001"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === GHOST BUTTON (閉じるなどの補助ボタン) === -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource AmberBrush}"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="{DynamicResource AmberBorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AmberHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === COMBOBOX ITEM (テーマ対応) === -->
        <Style x:Key="DarkComboItem" TargetType="ComboBoxItem">
            <Setter Property="Background"                 Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="Foreground"                 Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontFamily"                 Value="Consolas"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Padding"                    Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ComboHighBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === COMBOBOX (テーマ対応) === -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background"                 Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="Foreground"                 Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"                Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness"            Value="1"/>
            <Setter Property="Padding"                    Value="8,6"/>
            <Setter Property="FontFamily"                 Value="Consolas"/>
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ItemContainerStyle"         Value="{StaticResource DarkComboItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  Margin="8,6,0,6"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0"
                                                      Stroke="#8B949E" StrokeThickness="1.5"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextMuted}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent2Brush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide"
                                   Placement="Bottom">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <Border Background="{DynamicResource Surface2Brush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="6">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === SCROLLBAR === -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ======= UPDATE BANNER (hidden by default) ======= -->
        <Border x:Name="UpdateBanner" DockPanel.Dock="Top"
                Background="#1a2a0a" BorderBrush="#238636" BorderThickness="0,0,0,1"
                Padding="16,7" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎉 " FontSize="13"/>
                    <TextBlock x:Name="UpdateBannerText"
                               Text="新しいバージョンが公開されています！"
                               Foreground="#56D364" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border x:Name="UpdateLinkBd" Background="#238636" CornerRadius="4"
                            Padding="10,3" Margin="0,0,8,0" Cursor="Hand"
                            MouseLeftButtonDown="UpdateLink_Click">
                        <TextBlock Text="GitHubで確認  →" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Background="Transparent" CornerRadius="4" Padding="6,3" Cursor="Hand"
                            MouseLeftButtonDown="UpdateBannerClose_Click">
                        <TextBlock Text="✕" Foreground="#8B949E" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======= HEADER ======= -->
        <Border x:Name="HeaderBorder" DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🌐  ネットワーク構成図作成ツール"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="draw.io XML Generator for FortiGate / Cisco Networks"
                               FontSize="10" Foreground="{DynamicResource TextMuted}"
                               FontFamily="Consolas" Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Step indicators + drawio link + theme toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- テーマ切り替えボタン -->
                    <Border x:Name="ThemeToggleBd"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,5" Margin="0,0,14,0" Cursor="Hand"
                            MouseLeftButtonDown="ThemeToggle_Click"
                            ToolTip="ライト/ダークテーマを切り替え">
                        <TextBlock x:Name="ThemeToggleIcon" Text="☀" FontSize="13"
                                   Foreground="{DynamicResource TextMuted}"/>
                    </Border>
                    <!-- draw.io download link -->
                    <Border Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,5" Margin="0,0,14,0" Cursor="Hand"
                            MouseLeftButtonDown="DrawioLink_Click"
                            ToolTip="draw.io デスクトップ版をダウンロード (diagrams.net)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📥 " FontSize="11"/>
                            <TextBlock Text="draw.io DL" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="Si1" CornerRadius="12" Padding="12,4" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource Accent2Brush}" Background="Transparent">
                        <TextBlock x:Name="Si1Text" Text="① メモ読込" Foreground="{DynamicResource Accent2Brush}" FontSize="11"/>
                    </Border>
                    <Border x:Name="Si2" CornerRadius="12" Padding="12,4" Margin="0,0,6,0"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="Transparent">
                        <TextBlock x:Name="Si2Text" Text="② 接続設定" Foreground="{DynamicResource TextDim}" FontSize="11"/>
                    </Border>
                    <Border x:Name="Si3" CornerRadius="12" Padding="12,4"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="Transparent">
                        <TextBlock x:Name="Si3Text" Text="③ XML生成" Foreground="{DynamicResource TextDim}" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======= BODY ======= -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT MAIN AREA ===== -->
            <Grid Grid.Column="0">

                <!-- STEP 1: File input -->
                <Grid x:Name="PanelStep1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Width="560" Margin="0,40,0,40">
                            <!-- Drop zone -->
                            <Border x:Name="DropZone"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="2" CornerRadius="12"
                                    Padding="40,32" Margin="0,0,0,14"
                                    AllowDrop="True" Cursor="Hand"
                                    Drop="DropZone_Drop"
                                    DragOver="DropZone_DragOver"
                                    DragLeave="DropZone_DragLeave"
                                    MouseLeftButtonDown="DropZone_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📄" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="テキストファイルをドロップ" FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="またはクリックしてファイルを選択 (.txt)" FontSize="12"
                                               Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- OR divider -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Separator Grid.Column="0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text=" または直接貼り付け " Foreground="{DynamicResource TextDim}" FontSize="11" Margin="8,0"/>
                                <Separator Grid.Column="2" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Paste area -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
                                <TextBox x:Name="PasteArea" Height="180"
                                         Background="{DynamicResource SurfaceBrush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="12"
                                         Padding="12" AcceptsReturn="True"
                                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         Text="【構成機器】&#x0a;機器名　型番　IPアドレス&#x0a;機器名　型番　IPアドレス&#x0a;【構成以上】&#x0a;&#x0a;【以下メモ欄】&#x0a;構成メモをここに記述&#x0a;【メモ欄以上】"/>
                            </Border>

                            <Button x:Name="ParseButton"
                                    Content="▶  解析して接続設定へ"
                                    Style="{StaticResource BtnPrimary}"
                                    FontSize="14" Padding="28,10"
                                    HorizontalAlignment="Center"
                                    Click="ParseButton_Click"/>

                            <!-- OR divider -->
                            <Grid Margin="0,14,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Separator Grid.Column="0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text=" または " Foreground="{DynamicResource TextDim}" FontSize="11" Margin="8,0"/>
                                <Separator Grid.Column="2" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                            </Grid>

                            <Button Content="📥  draw.io ファイルから構成を復元"
                                    Style="{StaticResource BtnSecondary}"
                                    FontSize="13" Padding="20,9"
                                    HorizontalAlignment="Center"
                                    ToolTip="既存の draw.io XML (.drawio / .xml) から機器・接続関係を復元します"
                                    Click="ImportDrawio_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- STEP 2: Connection Builder -->
                <Grid x:Name="PanelStep2" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Toolbar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="接続ブロックを設定してください"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="←  戻る" Style="{StaticResource BtnSecondary}"
                                        Margin="0,0,8,0" Click="BackToStep1_Click"/>
                                <Button Content="📂  読込" Style="{StaticResource BtnSecondary}"
                                        Margin="0,0,8,0" Click="LoadConfig_Click"
                                        ToolTip="保存済みの設定ファイルを読み込む (.ndb.json)"/>
                                <Button Content="💾  保存" Style="{StaticResource BtnSecondary}"
                                        Margin="0,0,8,0" Click="SaveConfig_Click"
                                        ToolTip="現在の接続設定をJSONファイルに保存する"/>
                                <Button Content="XML生成  →" Style="{StaticResource BtnPrimary}"
                                        Click="GenerateXML_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Blocks scroll area -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="BlocksPanel" Margin="16,14,16,14"/>
                    </ScrollViewer>
                </Grid>

                <!-- STEP 3: Output -->
                <Grid x:Name="PanelStep3" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Toolbar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="✓  XML生成完了" Foreground="{DynamicResource GreenBrush}"
                                       FontWeight="Bold" VerticalAlignment="Center" FontSize="13"/>

                            <!-- ファイル名入力 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="ファイル名:"
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                    <TextBox x:Name="DiagramNameBox"
                                             Background="{DynamicResource Surface2Brush}"
                                             Foreground="{DynamicResource TextBrush}"
                                             CaretBrush="{DynamicResource TextBrush}" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="12"
                                             Padding="10,6" Width="220"
                                             VerticalAlignment="Center"
                                             Text="network_diagram"
                                             ToolTip="ファイル名とダイアグラム名に使われます（拡張子不要）"/>
                                </Border>
                                <TextBlock Text=".drawio"
                                           Foreground="{DynamicResource TextDim}" FontSize="11"
                                           FontFamily="Consolas" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="←  戻る" Style="{StaticResource BtnSecondary}"
                                        Margin="0,0,8,0" Click="BackToStep2_Click"/>
                                <Button Content="📋  コピー" Style="{StaticResource BtnGhost}"
                                        Margin="0,0,8,0" Click="CopyXML_Click"/>
                                <Button Content="⬇  .drawioとして保存" Style="{StaticResource BtnPrimary}"
                                        Click="SaveXML_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Output content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="OutputPanel" Margin="16,14,16,14"/>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ===== RIGHT PANEL: Memo + Device list ===== -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="80"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="220"/>
                    </Grid.RowDefinitions>

                    <!-- Memo header -->
                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Fill="#9E6A03"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="メモ欄" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMuted}"/>
                                <TextBlock x:Name="MemoEditHint" Text=" (編集可)" FontSize="10"
                                           Foreground="{DynamicResource TextDim}" FontStyle="Italic"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Memo content (editable) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="MemoDisplay"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextMuted}"
                                 BorderThickness="0" FontFamily="Consolas"
                                 FontSize="11" Padding="14,12"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 CaretBrush="{DynamicResource TextBrush}"
                                 TextChanged="MemoDisplay_TextChanged"
                                 ToolTip="クリックして編集できます"/>
                    </ScrollViewer>

                    <!-- Device list header -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,8,8,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="構成機器一覧" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextDim}"/>
                                <TextBlock Text="✦ チップをドラッグ&amp;ドロップで追加"
                                           FontSize="9" Foreground="{DynamicResource TextDim}" Margin="0,2,0,0"
                                           FontStyle="Italic"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="ToggleAddDeviceBtn"
                                    Content="＋ 機器追加"
                                    Style="{StaticResource BtnSecondary}"
                                    FontSize="10" Padding="8,4"
                                    Click="ToggleAddDevice_Click"
                                    ToolTip="機器を後から追加します"/>
                        </Grid>
                    </Border>

                    <!-- Add/Edit device form (collapsed by default) -->
                    <Border x:Name="AddDevicePanel" Grid.Row="3"
                            BorderBrush="{DynamicResource AmberBorderBrush}"
                            Background="{DynamicResource AmberHoverBrush}"
                            BorderThickness="0,1,0,1" Padding="12,10"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="AddDevPanelTitle" Text="機器を追加" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource AmberBrush}" Margin="0,0,0,8"/>
                            <!-- 名前 -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="名前" FontSize="10" Foreground="{DynamicResource TextDim}"
                                           VerticalAlignment="Center" FontFamily="Consolas"/>
                                <TextBox x:Name="AddDevNameBox" Grid.Column="1"
                                         Background="{DynamicResource Surface2Brush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11" Padding="6,4"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         ToolTip="機器名（必須）"/>
                            </Grid>
                            <!-- 型番 -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="型番" FontSize="10" Foreground="{DynamicResource TextDim}"
                                           VerticalAlignment="Center" FontFamily="Consolas"/>
                                <TextBox x:Name="AddDevModelBox" Grid.Column="1"
                                         Background="{DynamicResource Surface2Brush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11" Padding="6,4"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         ToolTip="型番（任意）"/>
                            </Grid>
                            <!-- IP -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="IP" FontSize="10" Foreground="{DynamicResource TextDim}"
                                           VerticalAlignment="Center" FontFamily="Consolas"/>
                                <TextBox x:Name="AddDevIPBox" Grid.Column="1"
                                         Background="{DynamicResource Surface2Brush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="11" Padding="6,4"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         ToolTip="IPアドレス（任意）"/>
                            </Grid>
                            <!-- ボタン -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="キャンセル" Style="{StaticResource BtnSecondary}"
                                        FontSize="10" Padding="8,4" Margin="0,0,6,0"
                                        Click="CancelAddDevice_Click"/>
                                <Button x:Name="ConfirmAddDeviceBtn" Content="✓ 追加" Style="{StaticResource BtnPrimary}"
                                        FontSize="10" Padding="8,4"
                                        Click="ConfirmAddDevice_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Device chips -->
                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DeviceChips" Margin="8,6,8,8"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
